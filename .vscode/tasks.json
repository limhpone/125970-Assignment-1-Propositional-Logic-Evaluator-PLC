{
	"version": "2.0.0",
	"tasks": [
        {
            "label": "start app",
            "type": "shell",
            "command": "uv",
            "args": ["run","main.py"],
            "options": {
                "cwd":"${workspaceFolder}/src/125970eval"
            }
        },
        {
            "label": "Install PySide6",
            "type": "shell",
            "command": "pip",
            "args": ["install", "pyside6"]
        },
        {
            "label": "Uninstall PySide6",
            "type": "shell",
            "command": "pip",
            "args": ["uninstall", "-y", "pyside6", "PySide6_Addons", "PySide6_Essentials"]
        }
	]
}